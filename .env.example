# BuildCraft environment variables
# Copy this file to .env and fill in your values

# Database (SQLite for local dev, swap to PostgreSQL/Supabase for production)
DATABASE_URL="file:./db/custom.db"

# Auth secret for session token signing (use a strong random string in production)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-this-to-a-strong-random-secret"

# Node environment
NODE_ENV="development"
